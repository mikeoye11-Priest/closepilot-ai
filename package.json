{
  "name": "closepilot-ai",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20.9 <23"
  },
  "scripts": {
    "dev": "next dev apps/web -p 3004",
    "build": "next build apps/web",
    "test": "npm run test:api && npm run build:web",
    "dev:web": "next dev apps/web -p 3004",
    "dev:qa": "CLOSEPILOT_AUTH_DISABLED=1 next dev apps/web -p 3010",
    "start:qa": "CLOSEPILOT_AUTH_DISABLED=1 next start apps/web -p 3010",
    "build:web": "next build apps/web",
    "dev:api": "uvicorn app.main:app --reload --app-dir apps/api",
    "test:api": "pytest apps/api/tests",
    "test:rules": "node qa/rule-validation/run-rule-validation.mjs",
    "test:rules:engine": "CLOSEPILOT_RULE_ENGINE_URL=${CLOSEPILOT_RULE_ENGINE_URL:-http://localhost:3010} node qa/rule-validation/run-rule-validation.mjs --engine",
    "test:finance-regression": "node qa/regression-tests/run-finance-regression.mjs",
    "test:import-recognition": "CLOSEPILOT_IMPORT_ENGINE_URL=${CLOSEPILOT_IMPORT_ENGINE_URL:-http://localhost:3010} node qa/regression-tests/run-import-recognition.mjs",
    "test:ai-explanations": "node qa/ai-explanations/run-ai-explanation-tests.mjs",
    "test:xero": "node --import tsx --test qa/xero-integration/xero-connector.test.ts",
    "test:upload": "CLOSEPILOT_QA_URL=${CLOSEPILOT_QA_URL:-http://localhost:3010} playwright test qa/upload-compat.spec.ts --browser=chromium --reporter=line",
    "test:upload-capacity": "node --import tsx --test qa/upload-capacity.test.ts",
    "test:worker": "node --import tsx --test qa/background-worker.test.ts",
    "test:ui": "CLOSEPILOT_QA_URL=${CLOSEPILOT_QA_URL:-http://localhost:3010} playwright test qa/button-smoke.spec.ts qa/pilot-walkthrough.spec.ts qa/visual-regression.spec.ts --browser=chromium --reporter=line",
    "verify": "npm run test && npm run test:rules && npm run test:finance-regression && npm run test:ai-explanations && npm run test:upload-capacity && npm run test:worker && npm run test:upload && npm run test:ui",
    "test:ui:install": "playwright install chromium",
    "check:launch": "node scripts/check-launch-readiness.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@e965/xlsx": "^0.20.3",
    "@google/generative-ai": "^0.24.1",
    "@sentry/nextjs": "^10.64.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "exceljs": "^4.4.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0",
    "tus-js-client": "^4.3.1",
    "xero-node": "^18.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.16",
    "uuid": "^11.1.1"
  }
}
