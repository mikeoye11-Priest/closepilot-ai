# Required for Preview and Production
NEXT_PUBLIC_SITE_URL=https://closepilot-ai-nvlz.vercel.app
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Storage bucket created by infra/storage_migration.sql
CLOSEPILOT_UPLOAD_BUCKET=finance-uploads
SUPABASE_SERVICE_ROLE_KEY=
INGESTION_WORKER_SECRET=

# Optional: grounded AI commentary. The deterministic assistant works without it.
GEMINI_API_KEY=

# Optional: Xero integration
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://closepilot-ai-nvlz.vercel.app/api/integrations/xero/callback
INTEGRATION_ENCRYPTION_KEY=

# Optional: QuickBooks integration (not required for Pilot 1)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=

# Optional: error tracking. Sentry is a no-op until a DSN is set, so the app
# builds and runs without these. Source-map upload only runs when an auth token
# is present.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Only needed to upload source maps at build time (CI/Vercel):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Local QA only. Never configure this in Vercel Preview or Production.
CLOSEPILOT_AUTH_DISABLED=0
